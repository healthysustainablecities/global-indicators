{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Example ES Las Palmas 2023 Configuration",
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "description": "Full study region name"
      },
      "country": {
        "type": "string",
        "description": "Full country name"
      },
      "country_code": {
        "type": "string",
        "description": "Two character country code (ISO3166 Alpha-2 code)"
      },
      "continent": {
        "type": "string",
        "description": "Continent name"
      },
      "year": {
        "type": "integer",
        "description": "Target year for analysis"
      },
      "crs": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the projected coordinate reference system (CRS)"
          },
          "standard": {
            "type": "string",
            "description": "Acronym of the standard catalogue defining this CRS"
          },
          "srid": {
            "type": "integer",
            "description": "Projected CRS spatial reference identifier (SRID)"
          }
        },
        "required": ["name", "standard", "srid"]
      },
      "study_region_boundary": {
        "type": "object",
        "properties": {
          "data": {
            "type": "string",
            "description": "Path to a region boundary vector file"
          },
          "source": {
            "type": "string",
            "description": "The name of the provider of this data"
          },
          "publication_date": {
            "type": ["string","integer"],
            "format": "date",
            "description": "Publication date for study region area data source"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL for the source dataset"
          },
          "licence": {
            "type": "string",
            "description": "Licence for the data"
          },
          "urban_intersection": {
            "type": "boolean",
            "description": "Whether the provided study region boundary will be further restricted to an urban area"
          },
          "citation": {
            "type": "string",
            "description": "A formal citation for this data"
          },
          "notes": {
            "type": ["string","null"],
            "description": "Optional notes of relevance for understanding this study region's context"
          }
        },
        "required": ["data", "source", "publication_date", "url", "licence", "citation"]
      },
      "custom_aggregations": {
        "type": "object",
        "patternProperties": {
          "^[a-zA-Z0-9_]+$": {
            "type": "object",
            "properties": {
              "data": {
                "type": "string",
                "description": "Path to data relative to project data folder"
              },
              "id": {
                "type": ["string","null"],
                "description": "The field used as a unique identifier"
              },
              "keep_columns": {
                "type": "string",
                "description": "A list of column field names to be retained"
              },
              "aggregation_source": {
                "type": "string",
                "description": "The indicator layer to be aggregated"
              },
              "weight": {
                "type": ["string", "boolean"],
                "description": "The variable used for weighting"
              },
              "note": {
                "type": ["string","null"],
                "description": "Note about the aggregation"
              }
            },
            "required": ["data"]
          }
        }
      },
      "population": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the population data"
          },
          "data_dir": {
            "type": "string",
            "description": "Path relative to project data directory to folder containing tifs, or a vector file"
          },
          "data_type": {
            "type": "string",
            "description": "Type of data"
          },
          "resolution": {
            "type": "string",
            "description": "Image resolution"
          },
          "raster_band": {
            "type": "integer",
            "description": "The image band containing the relevant data"
          },
          "raster_nodata": {
            "type": "integer",
            "description": "A value in the image that represents 'no data'"
          },
          "vector_population_data_field": {
            "type": "string",
            "description": "The field in the vector data containing population counts (this may be the same field used as 'population denominator', or a demographic sub-group count)."
          },
          "population_denominator": {
            "type": "string",
            "description": "The field in the vector data containing total population for the area."
          },
          "pop_min_threshold": {
            "type": "integer",
            "description": "Sample points intersecting grid cells with estimated population less than this will be excluded from analysis"
          },
          "crs_name": {
            "type": "string",
            "description": "Coordinate reference system metadata for population data"
          },
          "crs_standard": {
            "type": "string",
            "description": "CRS standard"
          },
          "crs_srid": {
            "type": "integer",
            "description": "CRS SRID"
          },
          "source_url": {
            "type": "string",
            "format": "uri",
            "description": "URL for where this data was sourced from"
          },
          "year_published": {
            "type": "integer",
            "description": "Year it was published"
          },
          "year_target": {
            "type": "integer",
            "description": "Year it is intended to represent"
          },
          "date_acquired": {
            "type": "integer",
            "description": "When you retrieved it"
          },
          "licence": {
            "type": "string",
            "description": "Licence"
          },
          "citation": {
            "type": "string",
            "description": "Citation"
          }
        },
        "required": ["name", "data_dir", "data_type", "resolution", "pop_min_threshold", "crs_name", "crs_standard", "crs_srid", "source_url", "year_published", "year_target", "date_acquired", "licence", "citation"],
        "allOf": [
          {
            "if": {
              "properties": {
                "data_type": { "const": "raster" }
              }
            },
            "then": {
              "required": ["raster_band", "raster_nodata"]
            }
          },
          {
            "if": {
              "properties": {
                "data_type": { "const": "vector" }
              }
            },
            "then": {
              "required": ["vector_population_data_field", "population_denominator"]
            }
          }
        ]
      },
      "OpenStreetMap": {
        "type": "object",
        "properties": {
          "data_dir": {
            "type": "string",
            "description": "Path relative to the project data directory"
          },
          "source": {
            "type": "string",
            "description": "The source of the OpenStreetMap data"
          },
          "publication_date": {
            "type": "integer",
            "description": "When it was published"
          },
          "licence": {
            "type": "string",
            "description": "Licence"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "The URL from where it was downloaded"
          },
          "note": {
            "type": ["string", "null"],
            "description": "An optional note regarding this data"
          }
        },
        "required": ["data_dir", "source", "publication_date", "licence", "url"]
      },
      "network": {
        "type": "object",
        "properties": {
          "intersection_tolerance": {
            "type": "integer",
            "description": "Tolerance in metres for cleaning intersections"
          }
        },
        "required": []
      },
      "urban_region": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name for the urban region data"
          },
          "data_dir": {
            "type": "string",
            "description": "Path to data relative to the project data directory"
          },
          "licence": {
            "type": "string",
            "description": "Licence"
          },
          "citation": {
            "type": "string",
            "description": "Citation for the GHSL UCDB"
          },
          "covariates": {
            "type": "object",
            "patternProperties": {
              "^[a-zA-Z0-9_]+$": {
                "type": "object",
                "properties": {
                  "Units": {
                    "type": "string",
                    "description": "Units"
                  },
                  "Unit description": {
                    "type": "string",
                    "description": "Unit description"
                  },
                  "Description": {
                    "type": "string",
                    "description": "Description"
                  }
                },
                "required": ["Units", "Unit description", "Description"]
              }
            }
          }
        },
        "required": ["name", "data_dir", "licence", "citation"]
      },
      "urban_query": {
        "type": ["string", "null"],
        "description": "Query used to identify the specific urban region relevant for this region"
      },
      "covariate_data": {
        "type": ["string", "null"],
        "description": "Additional study region summary covariates to be optionally linked"
      },
      "country_gdp": {
        "type": "object",
        "properties": {
          "classification": {
            "type": "string",
            "description": "Country GDP classification"
          },
          "citation": {
            "type": "string",
            "description": "Citation for the GDP classification"
          }
        },
        "required": ["classification", "citation"]
      },
      "gtfs_feeds": {
      "type": ["object", "null"],
      "properties": {
        "folder": {
          "type": "string",
          "description": "Path to the folder containing GTFS feeds"
        },
        "patternProperties": {
          "^[a-zA-Z0-9_]+$": {
            "type": "object",
            "properties": {
              "gtfs_provider": {
                "type": "string",
                "description": "Name of agency that published this data"
              },
              "gtfs_year": {
                "type": "integer",
                "description": "Year the data was published"
              },
              "gtfs_url": {
                "type": "string",
                "format": "uri",
                "description": "Source URL for the data"
              },
              "start_date_mmdd": {
                "type": "integer",
                "description": "The start date of a representative period for analysis"
              },
              "end_date_mmdd": {
                "type": "integer",
                "description": "The end date of a representative period for analysis"
              },
              "interpolate_stop_times": {
                "type": "boolean",
                "description": "To interpolate stop_times where these are missing"
              }
            },
            "required": ["gtfs_provider", "gtfs_year", "gtfs_url", "start_date_mmdd", "end_date_mmdd", "interpolate_stop_times"]
            }
          }
        }
      },
      "points_of_interest": {
      "type": ["object", "null"],
      "properties": {
        "patternProperties": {
          "^[a-zA-Z0-9_]+$": {
            "type": "object",
            "properties": {
              "data": {
                "type": "string",
                "description": "Path relative to the project data directory"
              },
              "source": {
                "type": "string",
                "description": "The source of the public open space data"
              },
              "publication_date": {
                "type": "integer",
                "description": "When it was published"
              },
              "licence": {
                "type": "string",
                "description": "Licence"
              },
              "url": {
                "type": "string",
                "format": "uri",
                "description": "The URL from where it was downloaded"
              }
            },
            "required": []
            }
          }
        }
      },
      "public_open_space": {
        "type": ["object", "null"],
        "properties": {
          "data": {
            "type": "string",
            "description": "Path relative to the project data directory"
          },
          "source": {
            "type": "string",
            "description": "The source of the public open space data"
          },
          "publication_date": {
            "type": "integer",
            "description": "When it was published"
          },
          "licence": {
            "type": "string",
            "description": "Licence"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "The URL from where it was downloaded"
          }
        },
        "required": ["data", "source", "publication_date", "licence", "url"]
      },
      "policy_review": {
        "type": ["string","null"],
        "description": "Optional path to include policy indicator checklist in generated reports"
      },
      "cycling_indicators": {
        "type": ["object","boolean","null"],
        "description": "Optional cycling Level of Traffic Stress (LTS) accessibility analysis.  Set to true to enable with defaults, or provide a mapping of options.",
        "properties": {
          "speed_limits": {
            "type": ["object","null"],
            "description": "Speed limit assignment used for LTS classification.",
            "properties": {
              "defaults": {
                "type": ["object","null"],
                "description": "Per-highway-type default speed limits (km/h), used where OSM maxspeed is missing."
              },
              "defaults_csv": {
                "type": ["string","null"],
                "description": "Path (under process/data) to a CSV with columns 'highway' and 'default_maxspeed' (alternative to 'defaults')."
              },
              "zones": {
                "type": ["array","null"],
                "description": "Optional spatial speed overrides; edges matching a zone take the zone speed.",
                "items": {
                  "type": "object",
                  "properties": {
                    "data": {"type": "string", "description": "Path (under process/data) to a polygon or line dataset (geojson/gpkg)."},
                    "layer": {"type": ["string","null"], "description": "Layer name for multi-layer datasets."},
                    "speed": {"type": "number", "description": "Speed (km/h) assigned to matched edges."},
                    "buffer": {"type": ["number","null"], "description": "Buffer (m) applied to line zone geometry before matching."},
                    "method": {"type": ["string","null"], "enum": ["overlap","intersects","within",null], "description": "Edge-to-zone match: 'overlap' (default; R bufferRatio), 'intersects' or 'within'."},
                    "overlap_threshold": {"type": ["number","null"], "description": "For method 'overlap': minimum share of the edge footprint within the zone (default 0.5)."},
                    "edge_buffer": {"type": ["number","null"], "description": "For method 'overlap': edge footprint width (m); default max(5, buffer/2)."},
                    "apply_to": {"type": ["string","null"], "enum": ["missing","all",null], "description": "Override only edges with a missing OSM speed ('missing', default, the R behaviour) or every matched edge ('all')."}
                  },
                  "required": ["data","speed"]
                }
              }
            }
          },
          "no_cycle": {
            "type": ["array","null"],
            "items": {"type": "string"},
            "description": "Highway classes on which cycling is not permitted."
          },
          "distances": {
            "type": ["array","null"],
            "items": {"type": "number"},
            "description": "Cycling catchment thresholds in metres, e.g. [2000, 5000]."
          },
          "destinations": {
            "type": ["array","null"],
            "description": "Destination specs to analyse; each maps a layer (optionally SQL-filtered) to an indicator name, tagged by category and strictness variant for the composite indicators.",
            "items": {
              "type": "object",
              "properties": {
                "name": {"type": "string", "description": "Indicator name, used in output column names."},
                "layer": {"type": "string", "description": "PostGIS destination layer (must have nearest-node associations)."},
                "where": {"type": ["string","null"], "description": "Optional SQL filter on the layer, e.g. \"dest_name = 'fresh_food_market'\" or 'headway <= 20'."},
                "category": {"type": ["string","null"], "description": "Destination category (e.g. food, pos, pt) grouping its variants."},
                "variant": {"type": ["string","null"], "description": "Strictness variant (e.g. strict, lenient); composite 'all categories' indicators are derived per variant."}
              },
              "required": ["name","layer"]
            }
          },
          "activity_centres": {
            "type": ["object","boolean","null"],
            "description": "Activity-centre (destination cluster) indicator. A centre is a network node whose pedestrian walk-shed reaches one of every required category; cycling safe-route access is measured to the nearest centre per tier. Set false to disable; true (default) uses the options below. May also be a map of named definitions (e.g. a 'local_custom' definition adding a locally-relevant category); a 'standard' definition is always included.",
            "properties": {
              "walk_threshold": {"type": ["number","null"], "description": "Pedestrian co-location radius in metres (default 400, ~5 min walk)."},
              "categories": {"type": ["array","null"], "items": {"type": "string"}, "description": "Destination categories that must co-locate (default [food, pos, pt])."},
              "tiers": {"type": ["object","null"], "description": "Map of tier name to the destination variant it is built from (default {local: lenient, complete: strict}).", "additionalProperties": {"type": "string"}}
            },
            "additionalProperties": {
              "type": "object",
              "description": "A named activity-centre definition.",
              "properties": {
                "walk_threshold": {"type": ["number","null"]},
                "categories": {"type": "array", "items": {"type": "string"}},
                "tiers": {"type": "object", "additionalProperties": {"type": "string"}}
              }
            }
          },
          "combined_access": {
            "type": ["object","null"],
            "description": "Named 'all categories reachable' composite indicator sets; each lists the categories to combine, evaluated across the strict and lenient variants. A 'standard' set over the global categories is always included (keeping comparable all_strict / all_lenient names); add e.g. a 'local_custom' set to also include a locally-relevant category (-> all_local_custom_strict / _lenient).",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "categories": {"type": "array", "items": {"type": "string"}, "description": "Destination categories combined in this set."}
              },
              "required": ["categories"]
            }
          }
        }
      },
      "notes": {
        "type": ["string", "null"],
        "description": "Optional additional notes for this region"
      },
      "reporting": {
        "type": ["object","null"],
        "properties": {
          "templates": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "PDF report templates"
          },
          "publication_ready": {
            "type": "boolean",
            "description": "Set 'publication_ready' to true once you have checked results"
          },
          "study_region_context_basemap": {
            "type": "string",
            "description": "Select a basemap for the study region report"
          },
          "doi": {
            "type": ["string", "null"],
            "description": "Once ready for publication it is recommended to register a DOI for your report"
          },
          "images": {
            "type": "object",
            "patternProperties": {
              "^[0-9]+$": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "description": "Image file path"
                  },
                  "description": {
                    "type": "string",
                    "description": "Image description"
                  },
                  "credit": {
                    "type": "string",
                    "description": "Image credit"
                  }
                },
                "required": ["file", "description", "credit"]
              }
            }
          },
          "languages": {
            "type": "object",
            "patternProperties": {
              "^[a-zA-Z0-9_ -]+$": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "City name in the specified language"
                  },
                  "country": {
                    "type": "string",
                    "description": "Country name in the specified language"
                  },
                  "summary_policy": {
                    "type": "string",
                    "description": "Summary of policy indicator results"
                  },
                  "summary_spatial": {
                    "type": "string",
                    "description": "Summary of spatial indicator results"
                  },
                  "summary_policy_spatial": {
                    "type": "string",
                    "description": "Summary of both policy and spatial indicator results"
                  },
                  "context":  {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "patternProperties": {
                        "^[a-zA-Z0-9_ -]+$": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "summary": {
                                "type": "string",
                                "description": "Contextual information about your study region"
                              },
                              "source": {
                                "type": "string",
                                "description": "Citations used"
                              }
                            },
                            "required": []
                          }
                        }
                      }
                    }
                  }
                },
                "required": ["name", "country"]
              }
            }
          },
          "exceptions": {
            "type": "object",
            "patternProperties": {
              "^[a-zA-Z0-9_ -]+$": {
                "type": "object",
                "patternProperties": {
                  "^[a-zA-Z0-9_ -]+$": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "optional_scorecard_context_statistics": {
            "type": "object",
            "properties": {
              "Gini": {
                "type": "object",
                "properties": {
                  "value": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
                  "year": { "type": "number", "minimum": 1000, "maximum": 3000 },
                  "source": { "type": "string"}
                },
                "required": []
              },
              "HDI": {
                "type": "object",
                "properties": {
                  "value": { "type": "number", "minimum": 0, "maximum": 1 },
                  "year": { "type": "number", "minimum": 0, "maximum": 2500 },
                  "source": { "type": "string"}
                },
                "required": []
              },
              "GDP per capita": {
                "type": "object",
                "properties": {
                  "value": { "type": "number", "minimum": 0 },
                  "year": { "type": "number", "minimum": 0, "maximum": 2500 },
                  "source": { "type": "string"}
                },
                "required": []
              },
              "City area (km²)": {
                "type": "object",
                "properties": {
                  "value": { "type": "number", "minimum": 0 },
                  "year": { "type": "number", "minimum": 0, "maximum": 2500 },
                  "source": { "type": "string"}
                },
                "required": []
              },
              "City population": {
                "type": "object",
                "properties": {
                  "value": { "type": "number", "minimum": 0},
                  "year": { "type": "number", "minimum": 0, "maximum": 2500 },
                  "source": { "type": "string"}
                },
                "required": []
              }
            },
            "required": []
          }
        },
        "required": []
      }
    },
    "required": ["name", "country", "country_code", "continent", "year", "crs", "study_region_boundary", "population", "OpenStreetMap"]
  }
